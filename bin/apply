#!/usr/bin/env bash
# apply — rebuild and switch to this configuration
# Usage: ./bin/apply [host]
#   host defaults to "default" if not specified

set -euo pipefail

DOTFILES_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
HOST="${1:-default}"

echo "→ Rebuilding ${HOST}..."
sudo nixos-rebuild switch --flake "${DOTFILES_DIR}#${HOST}"
echo "✓ Done"
